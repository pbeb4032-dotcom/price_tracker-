# Production Environment Configuration
# Copy this to .env and fill in your values

# Database Configuration
DB_PASSWORD=secure-production-password-2026
DB_PORT=5432

# JWT Configuration (Generate secure random strings)
APP_JWT_SECRET=production-jwt-secret-key-256-bits-long-for-security
INTERNAL_JOB_SECRET=production-internal-job-secret-key
DEV_LOGIN_SECRET=production-dev-login-secret

# Frontend Configuration
VITE_API_BASE_URL=https://price-tracker-iraq.com/api

# Monitoring & Observability
SENTRY_DSN=https://demo-dsn@sentry.io/demo-project
SENTRY_ENVIRONMENT=production

# Logging
LOG_LEVEL=warn

# Email Configuration (if needed)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# Redis Configuration (if using Redis)
# REDIS_URL=redis://redis:6379

# Security
# CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com
