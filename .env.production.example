# Price Tracker Iraq - Production Environment Configuration
# Copy this file to .env.production and replace every placeholder before deploying.

# Database
DB_PASSWORD=change-me-production-db-password
DATABASE_URL=postgresql://price_tracker_prod:change-me-production-db-password@postgres:5432/price_tracker_prod

# Cache
REDIS_URL=redis://redis:6379

# API secrets
APP_JWT_SECRET=change-me-production-app-jwt-secret
INTERNAL_JOB_SECRET=change-me-production-internal-job-secret
DEV_LOGIN_SECRET=

# Frontend
VITE_API_BASE_URL=https://price-tracker-iraq.com/api

# Monitoring
GRAFANA_ADMIN_PASSWORD=change-me-grafana-password
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
LOG_LEVEL=warn

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Push notifications
VAPID_EMAIL=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Optional compatibility settings
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_CLERK_PUBLISHABLE_KEY=
