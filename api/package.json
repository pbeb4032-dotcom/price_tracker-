{
  "name": "price-tracker-iraq-api",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "lint": "eslint .",
    "typecheck": "node node_modules/typescript/lib/tsc.js -p tsconfig.json --noEmit",
    "test": "vitest run --config ./vitest.config.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prove:db:live": "node node_modules/tsx/dist/cli.mjs scripts/check-live-db-governance.ts",
    "prove:governance:offline": "node node_modules/tsx/dist/cli.mjs scripts/check-governance-e2e.ts",
    "prove:db:fixture": "node node_modules/tsx/dist/cli.mjs scripts/check-live-db-fixture-conflicts.ts",
    "prove:db:preflight": "node node_modules/tsx/dist/cli.mjs scripts/check-db-preflight.ts",
    "prove:db:bundle": "node node_modules/tsx/dist/cli.mjs scripts/check-db-proof-bundle.ts",
    "prove:release:bundle": "node ../scripts/run-final-release-gate.mjs"
  },
  "dependencies": {
    "@hono/node-server": "^1.12.0",
    "@hono/swagger-ui": "^0.6.1",
    "@sentry/node": "^8.40.0",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.36.4",
    "hono": "^4.6.8",
    "ioredis": "^5.4.1",
    "jose": "^5.9.6",
    "nodemailer": "^6.9.16",
    "pg": "^8.13.1",
    "prom-client": "^15.1.3",
    "web-push": "^3.6.7",
    "winston": "^3.17.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.16.5",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.11.10",
    "@types/web-push": "^3.6.4",
    "@types/winston": "^2.4.4",
    "@vitest/coverage-v8": "^2.1.8",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
