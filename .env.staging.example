# Price Tracker Iraq - Staging Environment Configuration
# Copy this file to .env.staging and fill in the values

# Database Configuration
DB_PASSWORD=staging_password_123
DB_PORT=54321

# Application Secrets
APP_JWT_SECRET=staging_jwt_secret_change_this_in_production_$(openssl rand -hex 32)
INTERNAL_JOB_SECRET=staging_job_secret_change_this_in_production_$(openssl rand -hex 32)

# Redis Configuration
REDIS_PASSWORD=staging_redis_pass
REDIS_PORT=6379

# Monitoring
SENTRY_DSN=https://your-sentry-dsn-for-staging@sentry.io/project
GRAFANA_ADMIN_PASSWORD=staging_admin_123

# Email Configuration (for staging testing)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-staging-email@gmail.com
SMTP_PASS=your-staging-app-password
SMTP_FROM=staging@price-tracker-iraq.com

# Push Notifications (for staging testing)
VAPID_EMAIL=staging@price-tracker-iraq.com
VAPID_PUBLIC_KEY=your-staging-vapid-public-key
VAPID_PRIVATE_KEY=your-staging-vapid-private-key

# Frontend Configuration
VITE_API_BASE_URL=http://localhost:8787

# Feature Flags
ENABLE_LOCAL_SCHEDULER=1
ENABLE_SHADOW_AUTOMATION=1
ENABLE_AUTO_DISCOVERY_SCHEDULER=1
ENABLE_AUTO_SECTOR_TAG_CATALOG_SCHEDULER=1

# Logging
LOG_LEVEL=info
SENTRY_ENVIRONMENT=staging

# Database Pool
DB_POOL_MAX=25
