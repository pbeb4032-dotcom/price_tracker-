# Price Tracker Iraq - Staging Environment Configuration
# Copy this file to .env.staging and fill in the values before running setup-staging.sh.

# Database
DB_PASSWORD=change-me-staging-db-password
DB_PORT=54321

# API secrets
APP_JWT_SECRET=change-me-staging-app-jwt-secret
INTERNAL_JOB_SECRET=change-me-staging-internal-job-secret
DEV_LOGIN_SECRET=

# Cache
REDIS_PASSWORD=change-me-staging-redis-password
REDIS_PORT=6379

# Monitoring
GRAFANA_ADMIN_PASSWORD=change-me-staging-grafana-password
SENTRY_DSN=
SENTRY_ENVIRONMENT=staging
LOG_LEVEL=info

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Push notifications
VAPID_EMAIL=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Frontend
VITE_API_BASE_URL=http://localhost:8787

# Feature flags
ENABLE_LOCAL_SCHEDULER=1
ENABLE_SHADOW_AUTOMATION=1
ENABLE_AUTO_DISCOVERY_SCHEDULER=1
ENABLE_AUTO_SECTOR_TAG_CATALOG_SCHEDULER=1

# Database pool
DB_POOL_MAX=25
